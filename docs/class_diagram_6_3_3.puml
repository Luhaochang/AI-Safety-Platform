@startuml 防御配置与效果评测模块类图

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classAttributeFontSize 11
skinparam classStereotypeFontSize 10
skinparam packageFontSize 14
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50

package "防御配置与效果评测模块" {

    class DefenseCoordinator {
        - pipeline_stages: List[str]
        - execution_log: List[dict]
        + process_query(query): dict
        + execute_pipeline(query, evidence): dict
        + get_pipeline_status(): dict
        + run_defense_test(test_config): dict
    }

    class InputGuard {
        - enabled: bool
        - unicode_normalize: bool
        - injection_detector: Classifier
        - sensitive_filter: FilterChain
        + check_input(query): GuardResult
        + detect_injection(text): bool
        + normalize_input(text): str
        + get_risk_score(text): float
    }

    class RetrievalGuard {
        - enabled: bool
        - expand_factor: int
        - z_score_threshold: float
        - ppl_threshold: float
        - ppl_model: LanguageModel
        + filter_evidence(candidates): List[Evidence]
        + expand_retrieval(query, k, alpha): List[Evidence]
        + detect_embedding_anomaly(evidence): bool
        + detect_ppl_anomaly(evidence): bool
        + rank_evidence(evidence_list): List[Evidence]
    }

    class OutputGuard {
        - enabled: bool
        - consistency_threshold: float
        - business_rules: List[Rule]
        + verify_output(answer, evidence): GuardResult
        + check_consistency(answer, evidence): float
        + apply_constraints(answer): str
        + rewrite_answer(answer, evidence): str
    }

    class StrategyManager {
        - templates: List[dict]
        - active_strategy: dict
        - strategy_history: List[dict]
        + load_template(template_id): dict
        + save_config(config): bool
        + get_active_strategy(): dict
        + switch_strategy(template_id): bool
        + compare_strategies(id_a, id_b): dict
    }

    class GuardResult {
        - passed: bool
        - risk_score: float
        - blocked_count: int
        - detail: str
        + to_dict(): dict
    }
}

DefenseCoordinator ..> InputGuard : <<call>>
DefenseCoordinator ..> RetrievalGuard : <<call>>
DefenseCoordinator ..> OutputGuard : <<call>>
DefenseCoordinator ..> StrategyManager : <<use>>
InputGuard ..> GuardResult : <<create>>
OutputGuard ..> GuardResult : <<create>>
StrategyManager ..> InputGuard : <<use>>
StrategyManager ..> RetrievalGuard : <<use>>
StrategyManager ..> OutputGuard : <<use>>

@enduml
