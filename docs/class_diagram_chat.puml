@startuml 调度助手核心类图

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classAttributeFontSize 11
skinparam classStereotypeFontSize 10
skinparam packageFontSize 14
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50


package "调度助手模块" {

    class Conversation {
        - id: str
        - title: str
        - user: str
        - create_time: str
        - update_time: str
        - messages: List[Message]
        + add_message(message): void
        + to_dict(): dict
        + from_dict(data): Conversation
    }

    class Message {
        - role: str
        - content: str
        - time: str
        - references: List[Reference]
        + to_dict(): dict
        + from_dict(data): Message
    }

    class Reference {
        - title: str
        - section: str
        - relevance: float
        - text: str
        + to_dict(): dict
    }

    class Retriever {
        - sentence_model: SentenceTransformer
        - vector_store: VectorStore
        - bm25_available: bool
        + dense_retrieve(query, kb_ids, top_k): List[dict]
        + bm25_retrieve(query, documents, top_k): List[dict]
        + hybrid_retrieve(query, kb_ids, top_k): List[dict]
        - _rrf_fusion(dense_results, bm25_results, top_k): List[dict]
    }

    class Reranker {
        - cross_encoder: CrossEncoder
        + rerank(query, documents, top_k): List[dict]
    }

    class LLMGenerator {
        - api_key: str
        - api_url: str
        - default_model: str
        - available: bool
        - SYSTEM_PROMPT: str
        + generate(prompt, model): str
        + build_rag_prompt(query, contexts): str
        + check_connection(): bool
    }

    class RAGPipeline {
        - retriever: Retriever
        - reranker: Reranker
        - generator: LLMGenerator
        - metadata_mgr: MetadataManager
        + query(query, kb_ids, top_k, model): RAGResult
        - _build_fallback_answer(reranked): str
    }

    class RAGResult {
        - answer: str
        - contexts: List[dict]
        - initial_docs: List[dict]
        - references: List[Reference]
        + to_dict(): dict
    }

    class ConversationManager {
        - history_file: str
        + load_all(): List[dict]
        + get_conversation(conv_id): dict
        + save_message(conv_id, query, answer, references): str
        + delete_conversation(conv_id): void
    }
}

Conversation "1" *-- "*" Message
Message "1" *-- "*" Reference
RAGPipeline "1" o-- "1" Retriever
RAGPipeline "1" o-- "1" Reranker
RAGPipeline "1" o-- "1" LLMGenerator
RAGPipeline ..> RAGResult : <<create>>
RAGResult "1" *-- "*" Reference
ConversationManager ..> Conversation : <<create>>
Retriever --> VectorStore

@enduml
