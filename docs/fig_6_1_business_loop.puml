@startuml 平台业务闭环图

skinparam defaultTextAlignment center
skinparam padding 4
skinparam rectangleFontSize 12
skinparam arrowThickness 1.5
hide stereotype

skinparam rectangle<<env>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<atk>> {
    BackgroundColor #FFEBEE
    BorderColor #C62828
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<def>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<sit>> {
    BackgroundColor #FFF8E1
    BorderColor #F9A825
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<plan>> {
    BackgroundColor #F3E5F5
    BorderColor #7B1FA2
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<eval>> {
    BackgroundColor #FBE9E7
    BorderColor #D84315
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<box>> {
    BackgroundColor white
    BorderColor #666666
    RoundCorner 4
    FontSize 11
}
skinparam rectangle<<base>> {
    BackgroundColor #ECEFF1
    BorderColor #78909C
    BorderStyle dashed
    RoundCorner 8
}

together {
    rectangle "电力调度RAG应用（第三章）" as RAG <<base>> {
        rectangle "知识库管理" as r1 <<box>>
        rectangle "调度助手" as r2 <<box>>
        rectangle "决策审计" as r3 <<box>>
    }
}

together {
    rectangle "环境准备" as ENV <<env>> {
        rectangle "RAG环境装载" as e1 <<box>>
        rectangle "知识库初始化" as e2 <<box>>
        rectangle "模型资产装载" as e3 <<box>>
        rectangle "日志链路配置" as e4 <<box>>
    }
    
    rectangle "风险复现" as ATK <<atk>> {
        rectangle "毒化文本生成" as a1 <<box>>
        rectangle "知识库注入" as a2 <<box>>
        rectangle "攻击效果验证" as a3 <<box>>
    }
    
    rectangle "防御配置" as DEF <<def>> {
        rectangle "输入护栏" as d1 <<box>>
        rectangle "检索护栏" as d2 <<box>>
        rectangle "输出护栏" as d3 <<box>>
        rectangle "策略参数设置" as d4 <<box>>
    }
}

together {
    rectangle "态势感知" as SIT <<sit>> {
        rectangle "多源事件采集" as s1 <<box>>
        rectangle "攻击链关联" as s2 <<box>>
        rectangle "风险等级评估" as s3 <<box>>
    }
    
    rectangle "预案生成" as PLAN <<plan>> {
        rectangle "模板匹配" as p1 <<box>>
        rectangle "案例结合" as p2 <<box>>
        rectangle "处置建议生成" as p3 <<box>>
    }
    
    rectangle "评测复盘" as EVAL <<eval>> {
        rectangle "指标统计分析" as v1 <<box>>
        rectangle "过程回放" as v2 <<box>>
        rectangle "报告生成" as v3 <<box>>
    }
}

RAG -up-> ENV
ENV -right-> ATK
ATK -right-> DEF
DEF -down-> SIT
SIT -right-> PLAN
PLAN -right-> EVAL

@enduml
