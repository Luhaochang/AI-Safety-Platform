@startuml 效果评测与复盘分析模块类图

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classAttributeFontSize 11
skinparam classStereotypeFontSize 10
skinparam packageFontSize 14
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50

package "效果评测与复盘分析模块" {

    class TaskController {
        - task_registry: dict
        - active_task_id: str
        + create_task(scenario, config): str
        + start_task(task_id): bool
        + pause_task(task_id): bool
        + resume_task(task_id): bool
        + end_task(task_id): bool
        + get_task_status(task_id): dict
    }

    class Stage {
        - id: str
        - name: str
        - status: str
        - duration: str
        - start_time: str
        + to_dict(): dict
        + update_status(status): void
    }

    class ProcessScheduler {
        - task_flow: List[Stage]
        - current_stage: int
        - stage_results: dict
        + schedule(task_id): List[Stage]
        + execute_stage(stage_id): dict
        + advance(): bool
        + get_progress(task_id): dict
        + retry_stage(stage_id): bool
    }

    class MetricCalculator {
        - attack_metrics: dict
        - defense_metrics: dict
        - resource_metrics: dict
        + calculate_all(task_id): dict
        + compute_attack_metrics(logs): dict
        + compute_defense_metrics(logs): dict
        + compute_resource_metrics(logs): dict
        + compare_with_baseline(task_id): dict
    }

    class Report {
        - id: str
        - task_id: str
        - name: str
        - summary: str
        - metrics: dict
        - create_time: str
        + to_dict(): dict
    }

    class ReportGenerator {
        - report_template: str
        - generated_reports: List[Report]
        + generate_report(task_id, metrics): Report
        + format_summary(metrics): str
        + export_pdf(report_id): bytes
        + export_json(report_id): dict
        + list_reports(): List[Report]
    }

    class ReplayManager {
        - timeline: List[dict]
        - current_step: int
        - replay_speed: float
        + build_timeline(task_id): List[dict]
        + get_replay_data(task_id): dict
        + step_forward(): dict
        + step_backward(): dict
        + reset(): void
    }
}

ProcessScheduler "1" *-- "*" Stage
ReportGenerator "1" *-- "*" Report
TaskController ..> ProcessScheduler : <<call>>
ProcessScheduler ..> MetricCalculator : <<call>>
MetricCalculator ..> ReportGenerator : <<call>>
ReportGenerator ..> Report : <<create>>
TaskController ..> ReplayManager : <<call>>
ReplayManager ..> MetricCalculator : <<use>>

@enduml
