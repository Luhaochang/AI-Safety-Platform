@startuml 数字孪生映射架构图

skinparam defaultTextAlignment center
skinparam padding 4
skinparam nodesep 10
skinparam ranksep 10
skinparam rectangleFontSize 12
skinparam arrowThickness 1.5
hide stereotype

skinparam rectangle<<physical>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<sync>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<digital>> {
    BackgroundColor #FFF8E1
    BorderColor #F9A825
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<app>> {
    BackgroundColor #F3E5F5
    BorderColor #7B1FA2
    BorderStyle dashed
    RoundCorner 8
}
skinparam rectangle<<box>> {
    BackgroundColor white
    BorderColor #666666
    RoundCorner 4
    FontSize 11
}

rectangle "物理世界" as PW <<physical>> {
    rectangle "服务器/GPU/存储" as p1 <<box>>
    rectangle "多源数据" as p2 <<box>>
    rectangle "训练任务/推理服务" as p3 <<box>>
    rectangle "调度指令/业务流程" as p4 <<box>>
}

rectangle "虚实映射层" as SY <<sync>> {
    rectangle "监控代理" as s1 <<box>>
    rectangle "状态采集" as s2 <<box>>
    rectangle "接口调用" as s3 <<box>>
    rectangle "日志汇聚" as s4 <<box>>
    rectangle "分析反馈" as s5 <<box>>
    rectangle "告警下发" as s6 <<box>>
}

rectangle "数字空间" as DS <<digital>> {
    rectangle "资源孪生体" as d1 <<box>>
    rectangle "数据孪生体" as d2 <<box>>
    rectangle "模型孪生体" as d3 <<box>>
    rectangle "业务孪生体" as d4 <<box>>
}

rectangle "孪生应用" as AP <<app>> {
    rectangle "状态可视化监控" as a1 <<box>>
    rectangle "关系追溯与审计" as a2 <<box>>
    rectangle "推演仿真与决策" as a3 <<box>>
}

PW -down-> SY : 状态上报
SY -down-> DS : 数字化映射
DS -down-> AP : 孪生驱动
AP -up-> SY : 推演结果反馈
SY -up-> PW : 告警与控制下发

@enduml
